# =============================================================================
# Environment template — copy to `.env` and fill. NEVER commit `.env`.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Password is mandatory (docker-compose will refuse to start without it).
DB_NAME=microcrm
DB_USER=microcrm
DB_PASSWORD=change-me-to-a-long-random-string

# --- Host port mapping -------------------------------------------------------
# BACK_PORT is the direct port for the Spring Boot API (mandatory because
# the Angular config.ts hardcodes http://localhost:8080 as the API URL).
BACK_PORT=8080

# --- Reverse proxy (Traefik) -------------------------------------------------
# Dev defaults use high ports to avoid clashes with an Apache / Nginx / IIS
# already running on the developer's machine. Prod overrides to 80 / 443.
HTTP_PORT=8000
HTTPS_PORT=8443
# Traefik dashboard — insecure mode, no auth. DEV ONLY (prod disables it).
TRAEFIK_DASHBOARD_PORT=8090

# --- Domain & TLS ------------------------------------------------------------
# Dev: DOMAIN=localhost, the browser sends Host: localhost which Traefik
# matches to the front router. Prod: the real domain that points to the VPS.
DOMAIN=localhost
# Required in prod for Let's Encrypt account registration and expiry notices.
ACME_EMAIL=

# --- Image tagging (used mainly by CI/CD on the VPS) -------------------------
GITHUB_REPOSITORY_OWNER=
IMAGE_TAG=latest