# =============================================================================
# Environment template — copy to `.env` and fill. NEVER commit `.env`.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Password is mandatory (docker-compose will refuse to start without it).
DB_NAME=microcrm
DB_USER=microcrm
DB_PASSWORD=change-me-to-a-long-random-string

# --- Host port mapping -------------------------------------------------------
# Override defaults if the port is already in use on the host.
BACK_PORT=8080
FRONT_PORT=8081

# --- Image tagging (used mainly by CI/CD on the VPS) -------------------------
# GITHUB_REPOSITORY_OWNER is set automatically in GitHub Actions; locally you
# can leave it unset — the image reference defaults to `local/...`.
GITHUB_REPOSITORY_OWNER=
IMAGE_TAG=latest
